algoritmo "Cadastro Pessoas"

var
  i: inteiro
  nomes: vetor[0..9] caracter
  idades: vetor[0..9] inteiro
  estados: vetor[0..9] caracter
  cores: vetor[0..9] caracter

  indexPessoas: inteiro
  pessoas: vetor[0..9] caracter
inicio
  indexPessoas <- 0

  para i de 0 ate 9 faca
    escreval("Digite o seu nome")
    leia(nomes[i])

    escreval("Digite a sua idade")
    leia(idades[i])

    escreval("Digite o seu estado")
    leia(estados[i])

    escreval("Digite a sua cor favorita")
    leia(cores[i])
  fimpara

  para i de 0 ate 1 faca
    se(idades[i] > 25) entao
      se(estados[i] = "parana") entao
        se(cores[i] = "azul") entao
          pessoas[indexPessoas] <- nomes[i]
          indexPessoas <- indexPessoas + 1
        fimse
      fimse
    fimse
  fimpara

  para i de 0 ate indexPessoas faca
    escreval(pessoas[i])
  fimpara

fimalgoritmo
